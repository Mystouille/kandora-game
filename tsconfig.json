{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "~/game/*": ["./*"],
      "~/db/*": ["../db/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["routes/lobby.tsx", "routes/match.tsx", "routes/spectate.tsx"]
}
